GAME_PATH = '/SomePathToAmongUs/'
# If the app doesn't load, the directory may be incorrect, double check casesensitivity
#
# replace the SomePathToAmongUs to the path your Among Us Folder is in
# steamapps folder on Windows: C:/Program Files (x86)/Steam/steamapps/common/
# steamapps folder on Linux: /home/{user}/.steam/debian-installation/steamapps/common/
#
# GAME_PATH should be the root where Among Us has mods you wanna manage

LAUNCH_METHOD = 'SteamID'
# SteamID (Works on all systems but requires user to provide the AppID)
# Executable (Works only on Windows systems) (CURRENTLY NOT IMPLEMENTED)
STEAM_APP_ID = '945360'
# The App ID of Among Us on steam, you can find it somewhere in steam.
# Among Us' Official Steam ID: 945360
# If you're using a seperate install, setting it up as a Non-Steam game, you will have to look up how to find the ID.